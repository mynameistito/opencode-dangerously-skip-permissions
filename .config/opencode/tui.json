{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "opencode-win",
  "keybinds": {
    "session_parent": "ctrl+up",
    "session_child_cycle_reverse": "ctrl+left",
    "session_child_cycle": "ctrl+right",
    "session_child_first": "ctrl+down",
    "sidebar_toggle": "ctrl+s"
  },
  "scroll_speed": 10,
  "scroll_acceleration": {
    "enabled": true
  }
}
